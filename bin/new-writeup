#!/usr/bin/env bash
# Scaffold a short writeup / blog post (less rigid than research).
# Usage: bin/new-writeup "ctf-htb-foo"
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: $0 <slug>"
  exit 1
fi

SLUG="$1"
DATE="$(date +%Y-%m-%d)"
TIME="$(date +%H:%M:%S)"
TZ_OFFSET="$(date +%z)"
FILE="_posts/${DATE}-${SLUG}.md"

if [[ -e "$FILE" ]]; then
  echo "error: $FILE already exists"
  exit 1
fi

cat > "$FILE" <<MD
---
title: "TITLE HERE"
date: ${DATE} ${TIME} ${TZ_OFFSET}
categories: [Writeup]
tags: []
toc: true
lang: en
---

Intro paragraph.

## Section

Body.
MD

echo "[+] Created $FILE"
